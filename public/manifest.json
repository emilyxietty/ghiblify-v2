{
  "manifest_version": 3,
  "name": "Ghiblify",
  "version": "2.3.0",
  "description": "Studio Ghibli inspired new tab",
  "permissions": ["storage", "bookmarks", "search", "favicon", "geolocation"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Ghiblify — Options",
    "default_popup": "options.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "host_permissions": [
    "https://www.ghibli.jp/*",
    "https://*.imgur.com/*",
    "https://*.pinimg.com/*",
    "https://api.open-meteo.com/*",
    "https://api.bigdatacloud.net/*"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["background_en.json", "movie_metadata.json", "config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
