{
  "manifest_version": 3,
  "name": "Ghiblify",
  "version": "2.0.0",
  "description": "A Studio Ghibli–inspired new tab with widgets, themes, weather, pomodoro, sticky notes, quick links, and bookmarks.",
  "permissions": ["storage", "bookmarks", "search", "favicon", "geolocation"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Ghiblify — Options",
    "default_popup": "options.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://api.bigdatacloud.net/*"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
