{
  "manifest_version": 3,
  "name": "Ghiblify",
  "version": "2.3.1",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "permissions": ["storage", "bookmarks", "search", "favicon", "geolocation"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "options.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://api.bigdatacloud.net/*"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
